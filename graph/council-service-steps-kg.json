{
  "nodes": [
    { "id": "svc_report_it",     "label": "Report it",          "type": "service", "description": "A resident reports a problem — a pothole, a missed bin, fly-tipping — and expects it to be acted on." },
    { "id": "svc_apply_for",     "label": "Apply for something", "type": "service", "description": "A resident applies for a permit, licence, exemption or entitlement from the Council." },
    { "id": "svc_pay_for",       "label": "Pay for something",   "type": "service", "description": "A resident pays money owed to the Council — a bill, penalty, or charge." },
    { "id": "svc_book_it",       "label": "Book something",      "type": "service", "description": "A resident books a Council resource — a room, appointment, or collection." },
    { "id": "svc_get_support",   "label": "Get support",         "type": "service", "description": "A resident establishes eligibility for and receives ongoing Council support." },
    { "id": "svc_order_it",      "label": "Order something",     "type": "service", "description": "A resident orders a physical item from the Council — a bin, badge, or document." },
    { "id": "svc_stay_informed", "label": "Stay informed",       "type": "service", "description": "A resident finds information and tracks progress on something that matters to them." },

    { "id": "step_find",     "label": "Find",     "type": "step", "description": "The user wishes to find information, advice or guidance to help them achieve their goal." },
