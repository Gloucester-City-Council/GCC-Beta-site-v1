    { "id": "step_report",   "label": "Report",   "type": "step", "description": "The user wishes to report something that is wrong to the Council." },
    { "id": "step_request",  "label": "Request",  "type": "step", "description": "The user wants to request something from the Council." },
    { "id": "step_check",    "label": "Check",    "type": "step", "description": "The council needs to check whether a person is eligible for the service they are requesting." },
    { "id": "step_book",     "label": "Book",     "type": "step", "description": "The user needs to book a meeting, a room, or some other asset from the Council." },
    { "id": "step_apply",    "label": "Apply",    "type": "step", "description": "The user needs to apply for something from the Council, such as a permit or a licence." },
    { "id": "step_order",    "label": "Order",    "type": "step", "description": "The user wishes to order something from the Council." },
    { "id": "step_notify",   "label": "Notify",   "type": "step", "description": "The user needs to be notified about the status of their interaction with the Council." },
    { "id": "step_track",    "label": "Track",    "type": "step", "description": "The user wants to proactively track where things are at with their interaction with the Council." },
    { "id": "step_update",   "label": "Update",   "type": "step", "description": "The user wishes to update the Council with new information." },
    { "id": "step_pay",      "label": "Pay",      "type": "step", "description": "The user wants to pay some money they owe to the Council." },
    { "id": "step_feedback", "label": "Feedback", "type": "step", "description": "The user wants to let the Council know what they think." },

