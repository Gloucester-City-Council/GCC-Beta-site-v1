{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gloucester.gov.uk/schemas/icon-library/v1.1.0",
  "title": "GCC Icon Library",
  "description": "Standard icon library for Gloucester City Council digital services. Two parallel icon systems: (1) icon_library — Unicode emoji, zero dependency, for inline content; (2) svg_icons — open-source SVG sets, for UI components and service navigation.",
  "version": "1.1.0",
  "_publish_status": "draft",
  "_source": "Gloucester City Council — Head of Transformation and Commissioning",
  "_schema_url": "https://gloucester.gov.uk/schemas/icon-library/v1.1.0",
  "_changelog": [
    { "version": "1.1.0", "date": "2026-03-13", "note": "Added svg_icon_libraries metadata and svg_icons section mapping all canonical GCC icons across Lucide, Heroicons, Material Symbols, and Phosphor." },
    { "version": "1.0.0", "date": "2026-03-13", "note": "Initial emoji icon library." }
  ],

  "svg_icon_libraries": {
    "_description": "Approved open-source SVG icon libraries for GCC digital services. All permissively licensed — no attribution required in compiled output.",
    "_recommendation": "Default to Lucide. Use Material Symbols as fallback for icons not in Lucide's set. Use Heroicons when outline/solid toggle states are needed. Use Phosphor when weight variants (thin, bold, duotone) are required.",
    "libraries": [
      {
        "id": "lucide",
        "name": "Lucide",
        "licence": "MIT",
        "url": "https://lucide.dev",
        "icon_count": "1400+",
        "style": "Outline only, 1.5px stroke, rounded linecaps/joins",
        "recommended_for": "Primary library. Consistent, clean, municipal-appropriate. Navigation, forms, service pages.",
        "cdn_base": "https://unpkg.com/lucide-static/icons/",
        "cdn_bundle": "https://unpkg.com/lucide@latest/dist/umd/lucide.min.js",
        "install_npm": "npm install lucide-react",
        "usage_react": "import { Trash2 } from 'lucide-react'; <Trash2 size={24} />",
        "usage_html": "<img src=\"https://unpkg.com/lucide-static/icons/trash-2.svg\" width=\"24\" height=\"24\" alt=\"General waste\" />"
      },
      {
        "id": "heroicons",
        "name": "Heroicons",
        "licence": "MIT",
        "url": "https://heroicons.com",
        "icon_count": "292",
        "style": "Outline (1.5px stroke) and Solid (filled) variants per icon",
        "recommended_for": "When active/inactive toggle states are needed — outline = inactive, solid = active.",
        "cdn_base_outline": "https://unpkg.com/heroicons/24/outline/",
        "cdn_base_solid": "https://unpkg.com/heroicons/24/solid/",
        "install_npm": "npm install @heroicons/react",
        "usage_react": "import { TrashIcon } from '@heroicons/react/24/outline'; <TrashIcon className=\"size-6\" />"
      },
      {
        "id": "material",
        "name": "Material Symbols",
        "licence": "Apache 2.0",
        "url": "https://fonts.google.com/icons",
        "icon_count": "3000+",
        "style": "Outlined, Filled, Rounded, Sharp — variable font with weight/fill axes",
        "recommended_for": "Fallback when Lucide lacks the required icon. Also works as a web font with no SVG files needed.",
        "web_font_cdn": "https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined",
        "install_cdn": "<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined\" rel=\"stylesheet\">",
        "usage_html": "<span class=\"material-symbols-outlined\" aria-hidden=\"true\">search</span>"
      },
      {
        "id": "phosphor",
        "name": "Phosphor Icons",
        "licence": "MIT",
        "url": "https://phosphoricons.com",
        "icon_count": "9000+",
        "style": "Thin, Light, Regular, Bold, Fill, Duotone",
        "recommended_for": "When visual weight variants are needed (e.g. bold headings, light body, duotone decorative).",
        "cdn_base_regular": "https://unpkg.com/@phosphor-icons/core/assets/regular/",
        "install_npm": "npm install @phosphor-icons/react",
        "usage_react": "import { Trash } from '@phosphor-icons/react'; <Trash size={24} />"
      }
    ]
  },

